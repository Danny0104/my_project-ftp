# Field Training Platform — environment variables
# Copy to .env for local tooling, or set in Render/Railway/host dashboard.
# Yii reads these via getenv() in environments/prod/ config templates.
#
# Railway: see RAILWAY.md — MySQL plugin vars (MYSQLHOST, etc.) are auto-detected.

# Database
DB_DSN=mysql:host=127.0.0.1;dbname=my_project
DB_USER=root
DB_PASS=

# Cookie validation keys (generate: php -r "echo bin2hex(random_bytes(32));")
FRONTEND_COOKIE_KEY=
BACKEND_COOKIE_KEY=

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=tls
MAIL_FROM=noreply@example.com
MAIL_FROM_NAME=Field Training Platform
MAIL_SUPPORT=support@example.com

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_RETURN_URL=

# Facebook OAuth (optional)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Realtime chat — Socket.IO bridge (optional)
CHAT_WEBSOCKET_URL=
CHAT_BROADCAST_URL=

# Student ID OCR — path to tesseract binary (optional)
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux: /usr/bin/tesseract
TESSERACT_PATH=
